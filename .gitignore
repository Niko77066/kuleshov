# 密钥永不入库
.env

# Generated provider responses can contain expiring signed media URLs.
projects/**/shots/*result*.json
projects/**/shots/*status*.json

# 重媒体产物不进 git;留痕(film.json/md/prompt)与锚点图必须进
projects/**/*.mp4
projects/**/*.mov
projects/**/*.wav
projects/**/*.mp3
node_modules/
.DS_Store

# compose 中间产物(可由脚本复现)
projects/**/compose/bake_frames/
projects/**/compose/snapshots/
projects/**/compose/snap3d/
projects/**/compose/snapv2/
projects/**/shots/frames*/
projects/**/review_frames/
projects/**/compose/.hyperframes/
projects/**/shots/*-res.json
