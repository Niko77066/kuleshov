# Kuleshov · .env.example
# 仅列键名、不含值。本地开发 / 自带-key 路径用（film-ir adapters、检索、渲染、上传）。
#
# 交付给宿主 harness（grain / Codex）时：这些 provider key 由 harness 注入其自己的
# provider 工具，外挂容器内**不该持有**（见 README「本地-dev / 组织基建」两节）。
# G2 评委已去模型化（tools/judge/），不需要任何 key。

# —— 生成 / 音频 provider（film-ir adapters 的自带-key 本地路径；harness 下由宿主工具替代）——
MINIMAX_MUSIC_API_KEY=       # MiniMax TTS（speech-2.8-hd，旁白唯一 TTS 引擎）+ 音乐 BGM
MINIMAX_MUSIC_BASE_URL=
ARK_VIDEO_API_KEY=           # Seedance 视频生成（doubao-seedance-2-0）
ARK_VIDEO_API_BASE_URL=

# —— 检索素材 ——
PEXELS_API_KEY=
PIXABAY_API_KEY=
API_HUB_TOKEN=               # APIhub 时事新闻检索 / 下载

# —— 渲染（⚠ 组织基建：tools/render-remote.sh 焊死组织 VPN 出口 IP + 私有渲染机；
#          交付给宿主时由宿主的 HyperFrames 渲染器替代，见 README）——
FFMPEG_RENDER_HTTP_TOKEN=
RENDER_URL=

# —— OSS 上传（⚠ 组织 S3；同上，宿主自理）——
AWS_ACCESS_KEY=
AWS_SECRET_ACCESS_KEY=

# —— 其它 ——
KIMI_API_KEY=                # 旧网关；评委去模型化后非必需
